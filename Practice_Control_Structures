      "cell_type": "code",
      "source": [
        "def check_even_odd(num):\n",
        "    status = \"\"\n",
        "\n",
        "    if num % 2 == 0:\n",
        "        status = \"cüt\"\n",
        "    else:\n",
        "        status = \"tək\"\n",
        "\n",
        "    return status\n",
        "\n",
        "test_number = 37\n",
        "result = check_even_odd(test_number)\n",
        "print(f\"{test_number} ədədi {result}-dir\")\n"
