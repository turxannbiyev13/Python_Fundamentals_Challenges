        "def fizz_buzz(n):\n",
        "\n",
        "    final_result = \"\"\n",
        "\n",
        "    if n % 3 == 0 and n % 5 == 0:\n",
        "        final_result = \"FizzBuzz\"\n",
        "    elif n % 3 == 0:\n",
        "        final_result = \"Fizz\"\n",
        "    elif n % 5 == 0:\n",
        "        final_result = \"Buzz\"\n",
        "    else:\n",
        "        final_result = str(n)\n",
        "\n",
        "\n",
        "    return final_result\n",
        "\n",
        "# Test\n",
        "print(fizz_buzz(15))"
